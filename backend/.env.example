# === App URLs ===
API_URL=http://localhost:8000
APP_URL=http://localhost:3000

# === Azure OpenAI (private endpoint) ===
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://adminds-openai.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# === Azure Key Vault (optional — overrides env vars above) ===
# When set, secrets are loaded from Key Vault at startup using managed identity.
AZURE_KEYVAULT_URL=
